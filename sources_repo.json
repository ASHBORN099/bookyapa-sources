        "chapterTitle": "",
        "chapterLink": "",
        "chapterContent": "div#storytext",
        "chapterUrlPattern": "/s/{storyId}/{chapterNumber}/"
      }
    },
    {
      "id": "archive-of-our-own",
      "name": "Archive of Our Own",
