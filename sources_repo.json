{
  "name": "Bookyapa Sources",
  "sources": [
    {
      "id": "fanfiction-net",
      "name": "FanFiction.net",
      "baseUrl": "https://www.fanfiction.net",
      "lang": "en",
      "description": "The largest fan fiction archive. Millions of stories across every fandom imaginable.",
      "config": {
        "searchUrlPattern": "/search/?keywords={query}&type=story&ready=1",
        "searchResultContainer": "div.story-list div.z-list",
        "searchResultTitle": "a[data-ftype='title']",
        "searchResultLink": "a[data-ftype='title']",
        "searchResultCover": "",
        "searchResultAuthor": "a[data-ftype='author']",
        "exploreUrlPattern": "/book/Harry-Potter/",
        "bookTitle": "#profile_top b",
        "bookAuthor": "#profile_top a[href*='/u/']",
        "bookCover": "#storyimg",
        "bookDescription": "#profile_top div",
        "chapterListItem": "select#chap_select option",
        "chapterTitle": "",
        "chapterLink": "select#chap_select option",
        "chapterContent": "div#storytext"
      }
    },
    {
      "id": "archive-of-our-own",
      "name": "Archive of Our Own",
      "baseUrl": "https://archiveofourown.org",
      "lang": "en",
      "description": "A transformative work archive for fanfiction, fanart, and more. Run by the Organization for Transformative Works.",
      "config": {
        "searchUrlPattern": "/works/search?work_search%5Bquery%5D={query}",
        "searchResultContainer": "li.work.blurb",
        "searchResultTitle": "h4.heading a",
        "searchResultLink": "h4.heading a",
        "searchResultCover": "",
        "searchResultAuthor": "h4.byline a",
        "exploreUrlPattern": "/tags",
        "bookTitle": "h2.title",
        "bookAuthor": "h3 byline a",
        "bookCover": "",
        "bookDescription": "blockquote.userstuff",
        "chapterListItem": "ol.chapter.index.group li",
        "chapterTitle": "ol.chapter.index.group li a",
        "chapterLink": "ol.chapter.index.group li a",
        "chapterContent": "div#chapters div.chapter"
      }
    }
  ]
}
